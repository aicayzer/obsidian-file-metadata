{
  "name": "file-metadata",
  "version": "1.2.0",
  "description": "File Metadata plugin for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "deploy": "npm run build && cp main.js styles.css manifest.json /Users/aicayzer/aic-vault/.obsidian/plugins/file-metadata/"
  },
  "dependencies": {
    "exifr": "^7.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.56.1",
    "@typescript-eslint/utils": "^8.56.1",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.3",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "^1.7.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1"
  }
}
